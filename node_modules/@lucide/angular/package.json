{
  "name": "@lucide/angular",
  "description": "A Lucide icon library package for Angular applications.",
  "version": "1.17.0",
  "author": "karsa-mistmere",
  "license": "ISC",
  "homepage": "https://lucide.dev",
  "bugs": "https://github.com/lucide-icons/lucide/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucide-icons/lucide.git",
    "directory": "packages/angular"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "peerDependencies": {
    "@angular/common": "17.x - 21.x",
    "@angular/core": "17.x - 21.x"
  },
  "module": "fesm2022/lucide-angular.mjs",
  "typings": "types/lucide-angular.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/lucide-angular.d.ts",
      "default": "./fesm2022/lucide-angular.mjs"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "tslib": "^2.3.0"
  }
}